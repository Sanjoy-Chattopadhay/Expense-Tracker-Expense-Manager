# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use auto-detected writable path (./data/expenses.db or /tmp)
DB_PATH=

# ── Security ──────────────────────────────────────────────────────────────────
# Set to "false" only for local HTTP development; always "true" in production
SECURE_COOKIES=true

# ── Session & OTP ─────────────────────────────────────────────────────────────
SESSION_TTL_DAYS=30
OTP_TTL_MINUTES=10

# ── Google OAuth (Sign-In) ────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# ── MCP Endpoint ─────────────────────────────────────────────────────────────
# The public URL of your deployed MCP server (shown in the UI's "Connect" panel)
# Example: https://your-server.fastmcp.app/mcp
MCP_URL=

# ── Twilio OTP (optional — app falls back to demo/log mode if not set) ────────
# Create at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
